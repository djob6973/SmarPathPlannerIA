# Database — postgres.js connection string (required)
# Format: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://<user>:<password>@<host>:5432/<dbname>

# OpenAI — required for the AI chat agent
OPENAI_API_KEY=sk-proj-...

# Identity comes from Dokku's perimeter (oauth2-proxy + Google SSO), which
# injects X-Forwarded-Email on every request in production — there is no
# app-level login. Locally there's no perimeter, so set this to test as a
# given user. Never read/trusted when NODE_ENV=production.
DEV_USER_EMAIL=dev@dataico.com

# Comma-separated emails that always get super_admin on every login,
# regardless of when they first showed up. Prevents a named admin from ever
# ending up locked out with no role assigned.
ADMIN_EMAILS=

# Node environment
NODE_ENV=production
