# Database — postgres.js connection string (required)
# Format: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://<user>:<password>@<host>:5432/<dbname>

# OpenAI — required for the AI chat agent
OPENAI_API_KEY=sk-proj-...

# Google OAuth — optional, enables "Continuar con Google" on /login
# alongside the existing email/password form. Create credentials at
# https://console.cloud.google.com/apis/credentials with authorized
# redirect URI: https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated emails that always get super_admin on login (password or
# Google), regardless of when they first signed up. Prevents a named admin
# from ever ending up locked out with no role assigned.
ADMIN_EMAILS=

# Node environment
NODE_ENV=production
